{
  "name": "@employeeos/gateway",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "exports": {
    ".": "./dist/server.js"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsup src/server.ts --format esm --dts --out-dir dist",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@employeeos/ai": "workspace:*",
    "@employeeos/database": "workspace:*",
    "@employeeos/observer": "workspace:*",
    "@employeeos/reporter": "workspace:*",
    "@employeeos/shared": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.1",
    "@fastify/websocket": "^11.0.2",
    "fastify": "^5.3.3",
    "pino": "^9.3.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
